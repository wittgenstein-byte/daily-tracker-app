# KKU GenAI API key (server-side only — never committed, never shipped to the browser)
# Copy this file to `.env` (or `.env.local`) and fill in your real key.
# The Vite dev/preview server reads it at startup and uses it to authorize
# requests to https://gen.ai.kku.ac.th/api/v1/chat/completions.
AI_API_KEY=your_api_key_here
